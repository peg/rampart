{
  "id": "rampart",
  "name": "Rampart",
  "description": "AI agent firewall — YAML policy-as-code for every tool call",
  "activation": {
    "onStartup": true,
    "onCapabilities": [
      "hook"
    ]
  },
  "version": "0.9.22",
  "author": "peg",
  "homepage": "https://rampart.sh",
  "repository": "https://github.com/peg/rampart",
  "hooks": [
    "before_tool_call",
    "after_tool_call"
  ],
  "minHostVersion": "2026.3.28",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "serveUrl": {
        "type": "string",
        "default": "http://localhost:9090"
      },
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "timeoutMs": {
        "type": "number",
        "default": 3000,
        "minimum": 100,
        "maximum": 30000
      },
      "failOpen": {
        "type": "boolean",
        "description": "Deprecated coarse degraded-mode switch. Set false to block every tool when Rampart serve is unavailable. Prefer failOpenTools for per-tool control.",
        "default": true
      },
      "failOpenTools": {
        "type": "array",
        "description": "Tool names that may proceed when Rampart serve is unavailable or returns an evaluation error. Sensitive tools should normally be omitted.",
        "default": [
          "read",
          "web_fetch",
          "web_search",
          "image"
        ],
        "items": {
          "type": "string"
        },
        "uniqueItems": true
      },
      "approvalTimeoutMs": {
        "type": "number",
        "default": 120000,
        "minimum": 10000,
        "maximum": 600000
      }
    }
  }
}
