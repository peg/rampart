{
  "id": "rampart",
  "name": "Rampart",
  "description": "AI agent firewall — YAML policy-as-code for every tool call",
  "version": "0.9.22",
  "author": "peg",
  "homepage": "https://rampart.sh",
  "repository": "https://github.com/peg/rampart",
  "hooks": [
    "before_tool_call",
    "after_tool_call"
  ],
  "minHostVersion": "2026.3.28",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "serveUrl": {
        "type": "string",
        "default": "http://localhost:9090"
      },
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "timeoutMs": {
        "type": "number",
        "default": 3000,
        "minimum": 100,
        "maximum": 30000
      },
      "failOpen": {
        "type": "boolean",
        "default": true
      },
      "approvalTimeoutMs": {
        "type": "number",
        "default": 120000,
        "minimum": 10000,
        "maximum": 600000
      }
    }
  }
}
